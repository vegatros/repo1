//@version=5
indicator("Dual EMA 9/21 Cross", overlay=true)

// Input parameters for EMA lengths
emaFastLength = input.int(9, title="Fast EMA Length", minval=1)
emaSlowLength = input.int(21, title="Slow EMA Length", minval=1)

// Input parameters for colors
bullishColor = input.color(color.green, title="Bullish Color")
bearishColor = input.color(color.red, title="Bearish Color")

// Calculate EMAs
emaFast = ta.ema(close, emaFastLength)
emaSlow = ta.ema(close, emaSlowLength)

// Determine trend direction
isBullish = emaFast > emaSlow
isBearish = emaFast < emaSlow

// Set colors based on trend
fastEmaColor = isBullish ? bullishColor : bearishColor
slowEmaColor = isBullish ? bullishColor : bearishColor

// Plot EMAs with dynamic colors
plot(emaFast, title="Fast EMA", color=fastEmaColor, linewidth=2)
plot(emaSlow, title="Slow EMA", color=slowEmaColor, linewidth=2)

// Optional: Fill between EMAs
fillColor = isBullish ? color.new(bullishColor, 90) : color.new(bearishColor, 90)
fill(plot(emaFast), plot(emaSlow), color=fillColor, title="EMA Fill")

// Optional: Plot crossover signals
bullishCross = ta.crossover(emaFast, emaSlow)
bearishCross = ta.crossunder(emaFast, emaSlow)

plotshape(bullishCross, title="Bullish Cross", location=location.belowbar, 
          color=bullishColor, style=shape.triangleup, size=size.small)
plotshape(bearishCross, title="Bearish Cross", location=location.abovebar, 
          color=bearishColor, style=shape.triangledown, size=size.small)

// Alert conditions
alertcondition(bullishCross, title="Bullish Trend Change", 
              message="🟢 BULLISH SIGNAL: Fast EMA crossed above Slow EMA on {{ticker}}")
alertcondition(bearishCross, title="Bearish Trend Change", 
              message="🔴 BEARISH SIGNAL: Fast EMA crossed below Slow EMA on {{ticker}}")
alertcondition(bullishCross or bearishCross, title="Any Trend Change", 
              message="⚠️ TREND CHANGE: EMA crossover detected on {{ticker}}")