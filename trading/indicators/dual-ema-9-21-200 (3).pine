//@version=6
indicator("Dual EMA 9/21 Cross + 200 EMA Filter", overlay=true)

// Input parameters for EMA lengths
emaFastLength = input.int(9, title="Fast EMA Length", minval=1)
emaSlowLength = input.int(21, title="Slow EMA Length", minval=1)
emaTrendLength = input.int(200, title="Trend EMA Length", minval=1)

// Input parameters for colors
bullishColor = input.color(color.green, title="Bullish Color")
bearishColor = input.color(color.red, title="Bearish Color")
trendEmaColor = input.color(color.orange, title="200 EMA Color")

// Calculate EMAs
emaFast = ta.ema(close, emaFastLength)
emaSlow = ta.ema(close, emaSlowLength)
emaTrend = ta.ema(close, emaTrendLength)

// 200 EMA trend filter
aboveTrendEma = close > emaTrend
belowTrendEma = close < emaTrend

// Determine trend direction
isBullish = emaFast > emaSlow
isBearish = emaFast < emaSlow

// Set colors based on trend
fastEmaColor = isBullish ? bullishColor : bearishColor
slowEmaColor = isBullish ? bullishColor : bearishColor

// Plot EMAs with dynamic colors
p1 = plot(emaFast, title="Fast EMA", color=fastEmaColor, linewidth=2)
p2 = plot(emaSlow, title="Slow EMA", color=slowEmaColor, linewidth=2)
plot(emaTrend, title="200 EMA", color=trendEmaColor, linewidth=3)

// Fill between fast/slow EMAs
fillColor = isBullish ? color.new(bullishColor, 90) : color.new(bearishColor, 90)
fill(p1, p2, color=fillColor, title="EMA Fill")

// Raw crossover signals
bullishCrossRaw = ta.crossover(emaFast, emaSlow)
bearishCrossRaw = ta.crossunder(emaFast, emaSlow)

// Filtered signals: longs only above 200 EMA, shorts only below 200 EMA
bullishCross = bullishCrossRaw and aboveTrendEma
bearishCross = bearishCrossRaw and belowTrendEma

// Plot filtered crossover signals
plotshape(bullishCross, title="Bullish Cross (Filtered)", location=location.belowbar, 
          color=bullishColor, style=shape.triangleup, size=size.small)
plotshape(bearishCross, title="Bearish Cross (Filtered)", location=location.abovebar, 
          color=bearishColor, style=shape.triangledown, size=size.small)

// ── Alert Conditions (selectable individually in TradingView alert dropdown) ──
alertcondition(bullishCross, title="Bullish Signal", 
              message="🟢 BULLISH: Fast EMA crossed above Slow EMA, ABOVE 200 EMA on {{ticker}}")
alertcondition(bearishCross, title="Bearish Signal", 
              message="🔴 BEARISH: Fast EMA crossed below Slow EMA, BELOW 200 EMA on {{ticker}}")

// ── Combined Alert (if/else guarantees only one fires per bar) ───────
// Setup: Add alert → Condition: this indicator → "Any alert() function call"
if bullishCross
    alert("🟢 BULLISH: Fast EMA crossed above Slow EMA, ABOVE 200 EMA on " + syminfo.ticker, alert.freq_once_per_bar_close)
else if bearishCross
    alert("🔴 BEARISH: Fast EMA crossed below Slow EMA, BELOW 200 EMA on " + syminfo.ticker, alert.freq_once_per_bar_close)
