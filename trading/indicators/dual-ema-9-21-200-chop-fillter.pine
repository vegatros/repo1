//@version=6
indicator("Dual EMA 9/21 Cross + Trend Filters", overlay=true)

// ── Inputs: EMA Lengths ──────────────────────────────────────────────
emaFastLength  = input.int(9,   title="Fast EMA Length",  minval=1)
emaSlowLength  = input.int(21,  title="Slow EMA Length",  minval=1)
emaTrendLength = input.int(200, title="Trend EMA Length",  minval=1)

// ── Inputs: Chop / Trend Filters ─────────────────────────────────────
string grpChop     = "Choppiness Filters"
useAdx             = input.bool(true,   title="Enable ADX Filter",             group=grpChop)
adxLength          = input.int(14,      title="ADX Length",       minval=1,    group=grpChop)
adxThreshold       = input.float(20.0,  title="ADX Threshold (above = trending)", minval=1, group=grpChop)
useEmaSlope        = input.bool(true,   title="Enable 200 EMA Slope Filter",  group=grpChop)
emaSlopeLookback   = input.int(10,      title="EMA Slope Lookback Bars", minval=1, group=grpChop)
emaSlopeMin        = input.float(0.0,   title="Min EMA Slope (0 = any slope)", minval=0, step=0.01, group=grpChop, tooltip="Minimum absolute slope of the 200 EMA (in price units per bar). Set to 0 to simply require any non-flat slope.")
useBbSqueeze       = input.bool(false,  title="Enable Bollinger Squeeze Filter", group=grpChop)
bbLength           = input.int(20,      title="BB Length",        minval=1,    group=grpChop)
bbMult             = input.float(2.0,   title="BB Multiplier",   minval=0.1,  group=grpChop)
squeezeKcLength    = input.int(20,      title="Keltner Length",   minval=1,    group=grpChop)
squeezeKcMult      = input.float(1.5,   title="Keltner Multiplier", minval=0.1, group=grpChop)

// ── Inputs: Colors ───────────────────────────────────────────────────
string grpColors   = "Colors"
bullishColor       = input.color(color.green,  title="Bullish Color",  group=grpColors)
bearishColor       = input.color(color.red,    title="Bearish Color",  group=grpColors)
trendEmaColor      = input.color(color.orange, title="200 EMA Color",  group=grpColors)
showChopBackground = input.bool(true,          title="Shade Background When Choppy", group=grpColors)

// ── Inputs: Visual ───────────────────────────────────────────────────
string grpVisual   = "Visual"
showRejected       = input.bool(true, title="Show Rejected Signals (faded)", group=grpVisual)
showAdxPanel       = input.bool(false, title="Show ADX Value in Data Window", group=grpVisual)

// ═══════════════════════════════════════════════════════════════════════
// CALCULATIONS
// ═══════════════════════════════════════════════════════════════════════

// ── Core EMAs ────────────────────────────────────────────────────────
emaFast  = ta.ema(close, emaFastLength)
emaSlow  = ta.ema(close, emaSlowLength)
emaTrend = ta.ema(close, emaTrendLength)

// ── 200 EMA Directional Filter ───────────────────────────────────────
aboveTrendEma = close > emaTrend
belowTrendEma = close < emaTrend

// ── ADX Calculation (trend strength) ─────────────────────────────────
[diPlus, diMinus, adxValue] = ta.dmi(adxLength, adxLength)
adxTrending = adxValue >= adxThreshold

// ── 200 EMA Slope (directional momentum) ─────────────────────────────
emaSlope       = emaTrend - emaTrend[emaSlopeLookback]
emaSlopeUp     = emaSlope > emaSlopeMin
emaSlopeDown   = emaSlope < -emaSlopeMin

// ── Bollinger / Keltner Squeeze (volatility contraction) ─────────────
bbBasis   = ta.sma(close, bbLength)
bbDev     = bbMult * ta.stdev(close, bbLength)
bbUpper   = bbBasis + bbDev
bbLower   = bbBasis - bbDev

kcBasis   = ta.sma(close, squeezeKcLength)
kcRange   = squeezeKcMult * ta.atr(squeezeKcLength)
kcUpper   = kcBasis + kcRange
kcLower   = kcBasis - kcRange

// Squeeze is ON when BB is inside KC (low volatility / chop)
squeezeOn  = bbLower > kcLower and bbUpper < kcUpper
noSqueeze  = not squeezeOn

// ═══════════════════════════════════════════════════════════════════════
// COMPOSITE TREND FILTER
// ═══════════════════════════════════════════════════════════════════════

// Each filter is only enforced if its toggle is enabled
adxPass      = useAdx      ? adxTrending : true
slopePassUp  = useEmaSlope ? emaSlopeUp  : true
slopePassDn  = useEmaSlope ? emaSlopeDown : true
squeezePass  = useBbSqueeze ? noSqueeze  : true

// Combined: market is trending enough for longs / shorts
trendingForLong  = adxPass and slopePassUp  and squeezePass
trendingForShort = adxPass and slopePassDn  and squeezePass

// General "choppy" flag for background shading
isChoppy = (useAdx and not adxTrending) or (useEmaSlope and not emaSlopeUp and not emaSlopeDown) or (useBbSqueeze and squeezeOn)

// ═══════════════════════════════════════════════════════════════════════
// SIGNALS
// ═══════════════════════════════════════════════════════════════════════

// Determine visual trend
isBullish = emaFast > emaSlow
isBearish = emaFast < emaSlow

// Raw crossover events
bullishCrossRaw = ta.crossover(emaFast, emaSlow)
bearishCrossRaw = ta.crossunder(emaFast, emaSlow)

// Fully filtered signals
bullishCross = bullishCrossRaw and aboveTrendEma and trendingForLong
bearishCross = bearishCrossRaw and belowTrendEma and trendingForShort

// Rejected signals (for visual reference)
bullishRejected = bullishCrossRaw and not (aboveTrendEma and trendingForLong)
bearishRejected = bearishCrossRaw and not (belowTrendEma and trendingForShort)

// ═══════════════════════════════════════════════════════════════════════
// PLOTS
// ═══════════════════════════════════════════════════════════════════════

// ── EMA lines ────────────────────────────────────────────────────────
fastEmaColor = isBullish ? bullishColor : bearishColor
slowEmaColor = isBullish ? bullishColor : bearishColor

p1 = plot(emaFast,  title="Fast EMA",  color=fastEmaColor,  linewidth=2)
p2 = plot(emaSlow,  title="Slow EMA",  color=slowEmaColor,  linewidth=2)
plot(emaTrend, title="200 EMA", color=trendEmaColor, linewidth=3)

// ── EMA fill ─────────────────────────────────────────────────────────
fillColor = isBullish ? color.new(bullishColor, 90) : color.new(bearishColor, 90)
fill(p1, p2, color=fillColor, title="EMA Fill")

// ── Choppy background shading ────────────────────────────────────────
bgcolor(showChopBackground and isChoppy ? color.new(color.gray, 90) : na, title="Choppy Zone")

// ── Filtered signal markers ──────────────────────────────────────────
plotshape(bullishCross, title="Bullish Cross (Filtered)", location=location.belowbar, 
          color=bullishColor, style=shape.triangleup, size=size.small)
plotshape(bearishCross, title="Bearish Cross (Filtered)", location=location.abovebar, 
          color=bearishColor, style=shape.triangledown, size=size.small)

// ── Rejected signal markers (faded / tiny) ───────────────────────────
plotshape(showRejected and bullishRejected ? true : false, title="Bullish Cross (Rejected)", location=location.belowbar, 
          color=color.new(bullishColor, 80), style=shape.triangleup, size=size.tiny)
plotshape(showRejected and bearishRejected ? true : false, title="Bearish Cross (Rejected)", location=location.abovebar, 
          color=color.new(bearishColor, 80), style=shape.triangledown, size=size.tiny)

// ── ADX in data window (optional) ────────────────────────────────────
plot(showAdxPanel ? adxValue : na, title="ADX", color=color.new(color.purple, 0), display=display.data_window)

// ═══════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════
alertcondition(bullishCross, title="Bullish (Filtered)", 
              message="🟢 LONG: 9/21 cross above 200 EMA, trending market on {{ticker}}")
alertcondition(bearishCross, title="Bearish (Filtered)", 
              message="🔴 SHORT: 9/21 cross below 200 EMA, trending market on {{ticker}}")
alertcondition(bullishCross or bearishCross, title="Any Filtered Signal", 
              message="⚠️ FILTERED SIGNAL on {{ticker}}")
